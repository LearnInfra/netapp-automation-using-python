import urllib3
from netapp_ontap import HostConnection, config
from netapp_ontap.resources import SnapmirrorRelationship

# Suppress SSL warnings for lab environments
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

def create_snapmirror(dest_ip, user, password, source_path, dest_path):
    """
    Connects to the DESTINATION cluster to create a SnapMirror relationship.
    SnapMirror is always 'pulled' from the destination side.
    """
    conn = HostConnection(dest_ip, username=user, password=password, verify=False)
    
    with conn:
        # Define the SnapMirror Relationship object
        # Format for paths: "svm_name:volume_name"
        snmp_obj = SnapmirrorRelationship()
        snmp_obj.source_path = source_path
        snmp_obj.destination_path = dest_path
        snmp_obj.policy = "MirrorAllSnapshots"  # Standard Async policy
        
        try:
            # 1. Create the relationship
            snmp_obj.post()
            print(f"✅ Created: {source_path} -> {dest_path} on {dest_ip}")
            
            # 2. Initialize the relationship (Start the first data transfer)
            snmp_obj.patch(hydrate=True, initialize=True)
            print(f"🚀 Initialization started for {dest_path}")
            
        except Exception as e:
            print(f"❌ Failed on cluster {dest_ip}: {e}")

