import csv
import urllib3
from netapp_ontap import HostConnection, config
from netapp_ontap.resources import Volume

# Disable SSL warnings for lab/internal environments
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

def generate_capacity_report(cluster_ip, user, password, filename="netapp_report.csv"):
    # 1. Setup Connection
    conn = HostConnection(cluster_ip, username=user, password=password, verify=False)
    config.CONNECTION = conn

    with conn:
        try:
            # 2. Prepare CSV file
            with open(filename, mode='w', newline='') as file:
                writer = csv.writer(file)
                # Header Row
                writer.writerow(["SVM", "Volume Name", "Total Size (GB)", "Used (GB)", "Available (GB)", "Used %"])

                # 3. Fetch all volumes
                # We use fields="space,svm" to get specific data in one API call
                for volume in Volume.get_collection(fields="space,svm"):
                    volume.get()
                    
                    # Convert Bytes to GB for readability (1024^3)
                    gb_factor = 1024**3
                    total_gb = round(volume.space.size / gb_factor, 2)
                    used_gb = round(volume.space.used / gb_factor, 2)
                    avail_gb = round(volume.space.available / gb_factor, 2)
                    
                    # Handle division by zero for empty/new volumes
                    used_pct = round((used_gb / total_gb) * 100, 2) if total_gb > 0 else 0

                    # 4. Write data row
                    writer.writerow([
                        volume.svm.name,
                        volume.name,
                        total_gb,
                        used_gb,
                        avail_gb,
                        f"{used_pct}%"
                    ])

            print(f"✅ Success! Report saved as: {filename}")

        except Exception as e:
            print(f"❌ Failed to generate report: {e}")

if __name__ == "__main__":
    # Update with your cluster details
    generate_capacity_report("192.168.1.50", "admin", "NetApp123")
